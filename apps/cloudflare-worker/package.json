{
  "name": "markdown-processing-worker",
  "version": "1.0.0",
  "private": true,
  "description": "Cloudflare worker for parsing markdown files and updating metadata in a connected database",
  "main": "src/worker.js",
  "scripts": {
    "dev": "wrangler dev --local --config wrangler.flowershow.toml --env dev",
    "lint": "biome lint .",
    "deploy:staging": "npx wrangler deploy --config wrangler.flowershow.toml --keep-vars --env staging",
    "deploy:production": "npx wrangler deploy --config wrangler.flowershow.toml --keep-vars --env production",
    "test": "vitest run --config vitest.unit.config.js",
    "test:e2e": "vitest run --config vitest.e2e.config.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260621.1",
    "vitest": "^3.2.6",
    "wrangler": "^4.1.0"
  },
  "type": "module",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.0.0",
    "gray-matter": "^4.0.3",
    "image-size": "^2.0.2",
    "postgres": "^3.4.4",
    "remark": "^15.0.1",
    "strip-markdown": "^6.0.0",
    "typesense": "^2.0.3"
  }
}