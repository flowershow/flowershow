# Database Configuration (required for all environments)
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/flowershow-dev
TYPESENSE_HOST=localhost
TYPESENSE_PORT=8108
TYPESENSE_PROTOCOL=http
TYPESENSE_API_KEY=xyz # With document write permissions to all collections

# S3 Configuration (only needed for local development with MinIO)
# These can be removed in production/staging as we use R2 bindings there
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=flowershow
S3_ENDPOINT=http://localhost:9000
S3_FORCE_PATH_STYLE=true

# Optional S3 settings
S3_REGION=us-east-1  # Defaults to us-east-1 for MinIO if not set

# Sync workflow secrets
# SYNC_TRIGGER_SECRET: authenticates /sync requests from the Next.js app (same value as CF_SYNC_WORKER_SECRET in .env)
SYNC_TRIGGER_SECRET=some-shared-secret-between-nextjs-and-worker
# INTERNAL_API_SECRET: authenticates revalidation callbacks from the worker to Next.js
INTERNAL_API_SECRET=some-secret-the-worker-uses-to-call-back-nextjs
# NEXTJS_APP_URL: base URL of the Next.js app for revalidation callbacks
NEXTJS_APP_URL=http://localhost:3000