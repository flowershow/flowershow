{
  "name": "@flowershow/core",
  "version": "0.1.0",
  "description": "Shared utilities for the Flowershow platform",
  "type": "module",
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean --sourcemap",
    "lint": "biome lint .",
    "test": "vitest run"
  },
  "files": ["dist"],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "publishConfig": { "access": "public" },
  "devDependencies": {
    "tsup": "^8.5.0",
    "vitest": "^3.2.4"
  },
  "license": "MIT",
  "author": "Flowershow"
}
